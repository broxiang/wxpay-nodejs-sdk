{
  "types": [
    { "type": "feat", "section": "✨ 新功能 (Features)" },
    { "type": "fix", "section": "🐛 Bug 修复 (Bug Fixes)" },
    { "type": "perf", "section": "⚡ 性能优化 (Performance)" },
    { "type": "refactor", "section": "♻️ 重构 (Refactoring)", "hidden": true },
    { "type": "docs", "section": "📝 文档 (Documentation)", "hidden": true },
    { "type": "style", "section": "💄 代码风格 (Styling)", "hidden": true },
    { "type": "test", "section": "✅ 测试 (Tests)", "hidden": true },
    { "type": "chore", "section": "🔧 杂项 (Chores)", "hidden": true },
    { "type": "ci", "section": "🔄 CI/CD", "hidden": true },
    { "type": "revert", "section": "⏪ 回退 (Reverts)" }
  ],
  "commitUrlFormat": "https://github.com/broxiang/wxpay-nodejs-sdk/commit/{{hash}}",
  "compareUrlFormat": "https://github.com/broxiang/wxpay-nodejs-sdk/compare/{{previousTag}}...{{currentTag}}",
  "issueUrlFormat": "https://github.com/broxiang/wxpay-nodejs-sdk/issues/{{id}}",
  "releaseCommitMessageFormat": "chore(release): {{currentTag}}",
  "skip": {
    "changelog": false
  },
  "scripts": {
    "prerelease": "npm run build",
    "postchangelog": "prettier --write CHANGELOG.md"
  }
}
